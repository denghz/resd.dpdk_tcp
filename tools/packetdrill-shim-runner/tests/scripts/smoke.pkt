// Absolute-minimum lifecycle: connect, write, close.
--local_ip=10.99.2.2
--gateway_ip=10.99.2.1
--remote_ip=10.99.2.1

0.000 socket(..., SOCK_STREAM, IPPROTO_TCP) = 3
0.100 connect(3, ..., ...) = 0
0.100 > S  0:0(0) win 65535 <mss 1460,nop,wscale 3,sackOK,TS val 1 ecr 0>
0.200 < S. 0:0(0) ack 1 win 65535 <mss 1460,sackOK,TS val 100 ecr 1,nop,wscale 7>
0.200 > . 1:1(0) ack 1 <nop,nop,TS val 100 ecr 100>
0.300 close(3) = 0

From b104fe65181aadb5413e565ec23dc6c5bfa795a7 Mon Sep 17 00:00:00 2001
From: A7 Shim <a7-shim@local>
Date: Tue, 21 Apr 2026 16:27:49 +0000
Subject: [PATCH 4/5] shim: Makefile + tolerance adjustments

Adds dpdk_net_shim.o to the object list, drops -static so libdpdk_net's
DPDK deps can resolve at dynamic link time, and accepts EXT_CFLAGS /
EXT_LIBS from the environment so tools/packetdrill-shim/build.sh can
inject the dpdk-net link line without patching the Makefile.

Defaults tolerance_usecs to 0 because under the virtual clock the
scheduled time is the actual time -- no jiffy quantization or RT
scheduling slack. Scripts that want slack can still pass
--tolerance_usecs explicitly.
---
 gtests/net/packetdrill/Makefile.Linux  | 12 +++++++++++-
 gtests/net/packetdrill/Makefile.common |  2 +-
 gtests/net/packetdrill/config.c        |  8 +++++++-
 3 files changed, 19 insertions(+), 3 deletions(-)

diff --git a/gtests/net/packetdrill/Makefile.Linux b/gtests/net/packetdrill/Makefile.Linux
index 0c8b7ac..319f67e 100644
--- a/gtests/net/packetdrill/Makefile.Linux
+++ b/gtests/net/packetdrill/Makefile.Linux
@@ -1,2 +1,12 @@
-packetdrill-ext-libs := -lpthread -lrt -ldl -static
+# A7 shim: drop -static so we can dynamically link against libdpdk_net's
+# dependencies (DPDK EAL, ethdev, pthread, etc.). The real link-line is
+# assembled by tools/packetdrill-shim/build.sh via EXT_LIBS / EXT_CFLAGS
+# environment variables. Empty-default both so a bare `make -f
+# Makefile.Linux` still compiles.
+EXT_CFLAGS ?=
+EXT_LIBS ?=
+packetdrill-ext-libs := -lpthread -lrt -ldl $(EXT_LIBS)
 include Makefile.common
+# Append EXT_CFLAGS AFTER the common include so we override rather than
+# being overwritten by Makefile.common's `CFLAGS = -g -Wall -Werror`.
+CFLAGS += $(EXT_CFLAGS)
diff --git a/gtests/net/packetdrill/Makefile.common b/gtests/net/packetdrill/Makefile.common
index b614d08..61b6cb1 100644
--- a/gtests/net/packetdrill/Makefile.common
+++ b/gtests/net/packetdrill/Makefile.common
@@ -29,7 +29,7 @@ packetdrill-lib := \
          link_layer.o wire_conn.o wire_protocol.o \
          wire_client.o wire_client_netdev.o \
          wire_server.o wire_server_netdev.o \
-	 epoll.o pipe.o file.o so_testing.o wrap.o
+	 epoll.o pipe.o file.o so_testing.o wrap.o dpdk_net_shim.o
 
 packetdrill-objs := packetdrill.o $(packetdrill-lib)
 
diff --git a/gtests/net/packetdrill/config.c b/gtests/net/packetdrill/config.c
index b24215c..7dcb15c 100644
--- a/gtests/net/packetdrill/config.c
+++ b/gtests/net/packetdrill/config.c
@@ -290,7 +290,13 @@ void set_default_config(struct config *config)
 
 	config->tolerance_percent	= 12.5;
 
-	config->tolerance_usecs		= 4000;
+	/* A7 shim: under virtual time, the engine's clock is identical to
+	 * the scripted schedule — no jiffy quantization, no RT scheduling
+	 * slack, no bus contention. Default the tolerance to 0 so
+	 * deterministic scripts fail loudly on off-by-one-us drift; scripts
+	 * that want slack can still set --tolerance_usecs on the command
+	 * line. (The real-TUN path is unreachable under the shim.) */
+	config->tolerance_usecs		= 0;
 	config->speed			= TUN_DRIVER_SPEED_CUR;
 	config->mtu			= TUN_DRIVER_DEFAULT_MTU;
 

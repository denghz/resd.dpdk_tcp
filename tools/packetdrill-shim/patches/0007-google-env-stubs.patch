From 0744d4087d6e08889d6a030b082e6ede8ffe1ed7 Mon Sep 17 00:00:00 2001
From: dpdk-net shim <shim@dpdk-net.local>
Date: Thu, 23 Apr 2026 17:09:49 +0000
Subject: [PATCH] shim: stub defaults.sh + set_sysctls.py for CI environment

A8.5 T6: the Google packetdrill corpus invokes common/defaults.sh
and common/set_sysctls.py from a backtick init block. The upstream
scripts run `sysctl -q` / write to /proc/sys/net/... which requires
root and a Linux kernel TCP stack -- neither is available inside the
shim. Without this stub every script would exit 127 at the init step
before any TCP traffic flows.

gtests/net/tcp/common/defaults.sh is a symlink -> ../../common/
defaults.sh, so one stub file covers both TCP and non-TCP corpora.
gtests/net/tcp/common/set_sysctls.py is a real file and gets its own
no-op stub; all corpus references resolve there. The Python stub
also writes an empty /tmp/sysctl_restore_${PACKETDRILL_PID}.sh so
scripts that invoke that file at cleanup don't emit spurious exit-127
noise masking the real TCP-path failure.
---
 gtests/net/common/defaults.sh        | 70 ++++------------------------
 gtests/net/tcp/common/set_sysctls.py | 56 ++++++++--------------
 2 files changed, 28 insertions(+), 98 deletions(-)

diff --git a/gtests/net/common/defaults.sh b/gtests/net/common/defaults.sh
index 74b5915..ce6d3e3 100755
--- a/gtests/net/common/defaults.sh
+++ b/gtests/net/common/defaults.sh
@@ -1,62 +1,8 @@
-#!/bin/bash
-# Set standard production config values that relate to TCP behavior.
-
-# Flush old cached data (fastopen cookies).
-ip tcp_metrics flush all > /dev/null 2>&1
-
-# TCP min, default, and max receive and send buffer sizes.
-sysctl -q net.ipv4.tcp_rmem="4096 540000 $((15*1024*1024))"
-sysctl -q net.ipv4.tcp_wmem="4096 $((256*1024)) 4194304"
-
-# TCP timestamps.
-sysctl -q net.ipv4.tcp_timestamps=1
-
-# TCP SYN(ACK) retry thresholds
-sysctl -q net.ipv4.tcp_syn_retries=5
-sysctl -q net.ipv4.tcp_synack_retries=5
-
-# TCP Forward RTO-Recovery, RFC 5682.
-sysctl -q net.ipv4.tcp_frto=2
-
-# TCP Selective Acknowledgements (SACK)
-sysctl -q net.ipv4.tcp_sack=1
-
-# TCP Duplicate Selective Acknowledgements (DSACK)
-sysctl -q net.ipv4.tcp_dsack=1
-
-# TCP FACK (Forward Acknowledgement)
-sysctl -q net.ipv4.tcp_fack=0
-
-# TCP reordering degree ("dupthresh" threshold for entering Fast Recovery).
-sysctl -q net.ipv4.tcp_reordering=3
-
-# TCP congestion control.
-sysctl -q net.ipv4.tcp_congestion_control=cubic
-
-# TCP slow start after idle.
-sysctl -q net.ipv4.tcp_slow_start_after_idle=0
-
-# TCP RACK and TLP.
-sysctl -q net.ipv4.tcp_early_retrans=4 net.ipv4.tcp_recovery=1
-
-# TCP method for deciding when to defer sending to accumulate big TSO packets.
-sysctl -q net.ipv4.tcp_tso_win_divisor=3
-
-# TCP Explicit Congestion Notification (ECN)
-sysctl -q net.ipv4.tcp_ecn=0
-sysctl -q net.ipv4.tcp_ecn_option=2
-
-sysctl -q net.ipv4.tcp_pacing_ss_ratio=200
-sysctl -q net.ipv4.tcp_pacing_ca_ratio=120
-sysctl -q net.ipv4.tcp_notsent_lowat=4294967295 > /dev/null 2>&1
-
-sysctl -q net.ipv4.tcp_fastopen=0x70403
-sysctl -q net.ipv4.tcp_fastopen_key=a1a1a1a1-b2b2b2b2-c3c3c3c3-d4d4d4d4
-
-sysctl -q net.ipv4.tcp_syncookies=1
-
-# Override the default qdisc on the tun device.
-# Many tests fail with timing errors if the default
-# is FQ and that paces their flows.
-tc qdisc add dev tun0 root pfifo
-
+#!/bin/sh
+# A8.5 T6 stub. Real sysctl tuning (see upstream Google version under
+# this path) is not available inside the shim CI environment — we run
+# without root and without a Linux kernel TCP stack. Leaving sysctls
+# unchanged is safe for scripts that don't assert on specific values.
+# Scripts that DO call set_sysctls.py fall through to the stub in the
+# adjacent common/ directory.
+:
diff --git a/gtests/net/tcp/common/set_sysctls.py b/gtests/net/tcp/common/set_sysctls.py
index fb1dc29..457d515 100755
--- a/gtests/net/tcp/common/set_sysctls.py
+++ b/gtests/net/tcp/common/set_sysctls.py
@@ -1,41 +1,25 @@
 #!/usr/bin/env python3
+# A8.5 T6 stub. The real upstream set_sysctls.py writes to
+# /proc/sys/net/... which we cannot do inside the shim (no root, no
+# Linux kernel TCP stack). This stub accepts any "<proc-file>=<val>"
+# argument and exits 0, so scripts invoking it via packetdrill's
+# backtick init block do not abort with exit 127.
 #
-# Copyright 2012 Google Inc. All Rights Reserved.
-
-"""Sets sysctl values and writes a file that restores them.
-
-The arguments are of the form "<proc-file>=<val>" separated by spaces.
-The program first reads the current value of the proc-file and creates
-a shell script named "/tmp/sysctl_restore_${PACKETDRILL_PID}.sh" which
-restores the values when executed. It then sets the new values.
-
-PACKETDRILL_PID is set by packetdrill to the pid of itself, so a .pkt
-file could restore sysctls by running `/tmp/sysctl_restore_${PPID}.sh`
-at the end.
-"""
-
-__author__ = ('brakmo@google.com (Lawrence Brakmo)')
-
+# Scripts conventionally invoke /tmp/sysctl_restore_${PACKETDRILL_PID}.sh
+# at cleanup. The real upstream set_sysctls.py writes that file; to
+# avoid spurious "cleanup command non-zero 127" errors that mask the
+# real TCP-path failure, this stub writes an empty restore script too.
 import os
-import subprocess
 import sys
 
-filename = '/tmp/sysctl_restore_%s.sh' % os.environ['PACKETDRILL_PID']
-
-# Open file for restoring sysctl values
-restore_file = open(filename, 'w')
-print('#!/bin/bash', file=restore_file)
-
-for a in sys.argv[1:]:
-  sysctl = a.split('=')
-  # sysctl[0] contains the proc-file name, sysctl[1] the new value
-
-  # read current value and add restore command to file
-  cur_val = subprocess.check_output(['cat', sysctl[0]], universal_newlines=True)
-  print('echo "%s" > %s' % (cur_val.strip(), sysctl[0]), file=restore_file)
-
-  # set new value
-  cmd = 'echo "%s" > %s' % (sysctl[1], sysctl[0])
-  os.system(cmd)
-
-os.system('chmod u+x %s' % filename)
+pid = os.environ.get("PACKETDRILL_PID")
+if pid:
+    path = "/tmp/sysctl_restore_%s.sh" % pid
+    try:
+        with open(path, "w") as f:
+            f.write("#!/bin/sh\n:\n")
+        os.chmod(path, 0o755)
+    except OSError:
+        pass
+
+sys.exit(0)
-- 
2.34.1

